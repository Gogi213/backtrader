{
  "strategies": [
    {
      "key": "ZScoreSMA",
      "name": "Z-Score + SMA with SL/TP",
      "module": "panel_app.strategies.zscore_sma",
      "function": "run_zscore_sma_strategy",
      "arg_map": {
        "SMA Length": "sma_len",
        "ZScore Window": "z_window",
        "ZScore Threshold": "z_thresh",
        "Stop Loss (%)": "sl_pct",
        "Take Profit (%)": "tp_pct",
        "Use nATR Filter": "use_natr_filter",
        "Min nATR (%)": "natr_filter_min_pct"
      },
      "params": [
        {"name": "SMA Length", "type": "int", "default": 50, "step": 5},
        {"name": "ZScore Window", "type": "int", "default": 20, "step": 1},
        {"name": "ZScore Threshold", "type": "float", "default": 2.0, "step": 0.1},
        {"name": "Stop Loss (%)", "type": "float", "default": 1.0, "step": 0.1},
        {"name": "Take Profit (%)", "type": "float", "default": 3.0, "step": 0.1},
        {"name": "Use nATR Filter", "type": "bool", "default": false},
        {"name": "Min nATR (%)", "type": "float", "default": 0.5, "step": 0.1}
      ]
    },
    {
      "key": "KAMAZScore",
      "name": "KAMA + Adaptive Z-Score",
      "module": "panel_app.strategies.kama_zscore",
      "function": "run_kama_zscore_strategy",
      "arg_map": {
        "KAMA Period": "kama_period",
        "KAMA Fast SC": "kama_fast_sc",
        "KAMA Slow SC": "kama_slow_sc",
        "Z-Score Base Window": "z_base_window",
        "Z-Score nATR Multiplier": "z_natr_multiplier",
        "Z-Score Threshold": "z_threshold",
        "Stop Loss (%)": "sl_pct",
        "Take Profit (%)": "tp_pct",
        "Use nATR Filter": "use_natr_filter",
        "Min nATR (%)": "natr_filter_min_pct"
      },
      "params": [
        {"name": "KAMA Period", "type": "int", "default": 20, "step": 2},
        {"name": "KAMA Fast SC", "type": "int", "default": 2, "step": 1},
        {"name": "KAMA Slow SC", "type": "int", "default": 30, "step": 5},
        {"name": "Z-Score Base Window", "type": "int", "default": 10, "step": 1},
        {"name": "Z-Score nATR Multiplier", "type": "float", "default": 50.0, "step": 5.0},
        {"name": "Z-Score Threshold", "type": "float", "default": 2.0, "step": 0.1},
        {"name": "Stop Loss (%)", "type": "float", "default": 1.0, "step": 0.1},
        {"name": "Take Profit (%)", "type": "float", "default": 3.0, "step": 0.1},
        {"name": "Use nATR Filter", "type": "bool", "default": false},
        {"name": "Min nATR (%)", "type": "float", "default": 0.5, "step": 0.1}
      ]
    }
  ]
}
